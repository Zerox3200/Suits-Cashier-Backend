{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-suits-cashier-pos",
    "name": "Suits Cashier POS API",
    "description": "Postman collection for Suits Cashier backend.\n\n**Auth:** Send JWT in header `token` (not Authorization Bearer).\n\n**Default admin (seeded):**\n- email: `admin@suits.com`\n- password: `Admin@12345`\n\n**Flow tip:** Login first → token is saved automatically → create Category & Supplier → create Product (form-data with image) → adjust stock / create invoice.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:5200" },
    { "key": "token", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "supplierId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "invoiceId", "value": "" },
    { "key": "invoiceNumber", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      { "key": "key", "value": "token", "type": "string" },
      { "key": "value", "value": "{{token}}", "type": "string" },
      { "key": "in", "value": "header", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  if (res.data.user && res.data.user._id) {",
                  "    pm.collectionVariables.set('userId', res.data.user._id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@suits.com\",\n  \"password\": \"Admin@12345\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Public login. Saves `token` to collection variables on success."
          }
        },
        {
          "name": "Create User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Cashier One\",\n  \"email\": \"cashier@suits.com\",\n  \"password\": \"Cashier@123\",\n  \"confirmpassword\": \"Cashier@123\",\n  \"phone\": \"01012345678\",\n  \"role\": \"كاشير\"\n}"
            },
            "url": "{{baseUrl}}/auth/users",
            "description": "Admin only. Roles: `مسؤول` | `كاشير`."
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": "{{baseUrl}}/auth/users"
          }
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.category) {",
                  "  pm.collectionVariables.set('categoryId', res.data.category._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suits\",\n  \"description\": \"Formal suits\",\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/categories?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["categories"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" },
                { "key": "isActive", "value": "true", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "token", "value": "{{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Suits\",\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
            },
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Suppliers",
      "item": [
        {
          "name": "Create Supplier",
          "event": [
            {
              "listen": "test",
