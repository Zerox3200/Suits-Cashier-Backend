                { "key": "address", "value": "Cairo, Egypt", "type": "text" },
                { "key": "currency", "value": "EGP", "type": "text" },
                { "key": "defaultTax", "value": "0", "type": "text" },
                { "key": "receiptFooter", "value": "Thank you for shopping with us", "type": "text" },
                {
                  "key": "logo",
                  "type": "file",
                  "src": [],
                  "description": "Optional store logo"
                }
              ]
            },
            "url": "{{baseUrl}}/settings"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": "{{baseUrl}}/dashboard",
            "description": "Today/monthly sales, revenue, profit, product counts, OOS & low stock lists, recent invoices."
          }
        }
      ]
    },
    {
      "name": "Activity Logs",
      "item": [
        {
          "name": "List Activity Logs (Admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "token", "value": "{{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/activity-logs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["activity-logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
